# Frontend Environment Variables
#
# Copy this file to .env and fill in the values from your Supabase project dashboard.
# Dashboard → Settings → API
#
# ⚠️  ANON KEY ONLY — never put the service_role key here.
#     The anon key is safe to expose in the browser because RLS policies
#     on the database enforce access control per authenticated user.
#     The service_role key bypasses RLS entirely — keep it server-side only.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
